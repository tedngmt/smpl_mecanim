# This .gitignore is for a Unity project.
# Based on https://github.com/github/gitignore/blob/main/Unity.gitignore

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size, and could contain sensitive data
/[Mm]emoryCaptures/

# Recordings can get excessive in size
/[Rr]ecordings/

# Autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio / VS Code cache and workspace files
.vs/
.vscode/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated crash report
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# OS junk files
.DS_Store
Thumbs.db

# SMPL model package (https://smpl.is.tue.mpg.de) is licensed for research use only and
# may not be redistributed -- download it yourself and extract into assets/SMPL/.
# Only the C# SCRIPTS under Scripts/ are tracked (they carry our local modifications and
# are needed to compile). The licensed MODEL ASSETS stay out of git: the FBX models
# (Models/), the materials + textures (Samples/, Models/Materials/), the sample betas, and
# the joint-regressor data -- re-download and re-apply those from the SMPL site after clone.
/assets/SMPL/*
!/assets/SMPL/Scripts.meta
!/assets/SMPL/Scripts/
/assets/SMPL/Scripts/mpi/jnt_regressors/
/assets/SMPL/Scripts/mpi/jnt_regressors.meta

# Mocap animation clips (Idle/Walk/Run/Crouch FBX) bought from the Unity Asset Store
# (package #5330, https://www.assetstore.unity3d.com/en/#!/content/5330) -- not ours to
# redistribute. Re-import the package into assets/raw mocap data/ after cloning.
/assets/raw mocap data.meta
/assets/raw mocap data/
